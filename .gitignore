# ==============================================================================
# .gitignore — terraform-app
# ==============================================================================

# ── Terraform ─────────────────────────────────────────────────────────────
# Directorios .terraform locales
**/.terraform/*

# Archivos de estado
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Archivos .tfvars: suelen contener datos sensibles (passwords, claves). No versionar.
*.tfvars
*.tfvars.json
# Sí versiona los ejemplos:
!*.tfvars.example

# Override files (se usan para overrides locales)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Archivos de configuración de la CLI
.terraformrc
terraform.rc

# ── Secretos y variables de entorno ───────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ── Sistema operativo ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editores / IDE ────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*~
